# Credentials — never commit
.credentials.json

# Personal context brief — contains name, email, machine specs, API keys
# Friends/new machines use operator-context.template.md as their starting point
operator-context.md

# Hook-written session state — ephemeral, changes every session, not repo content
LAST-SESSION-STATE.md
CURRENT-STATE.md
settings.local.json
p6-config.json

# Per-instance memory — advisory, may contain credentials, never commit
memory/

# Session transcripts and per-project ephemeral state
projects/
sessions/
transcripts/
telemetry/
logs/
cache/
paste-cache/
shell-snapshots/
session-env/
backups/
uploads/
tasks/
state/
file-history/
tools/**/node_modules
plugins/

# Session-local ephemeral files
history.jsonl
.wudu_attestations
scheduled_tasks.lock
.last-cleanup
.turn-count.txt
cold-instance-test-*.txt

# Wudu / session attestation artifacts
*.attestation
